};freeview.evtsExt__header__dx_variable.userFunc0xc04fc8 = function GDJSInlineCode(runtimeScene, eventsFunctionContext) {
"use strict";

//load image server
//=========================================
const dbTest = returnprincipaldb();
let iddTest = 0;
const configserver = {
  imageSources: {
    0: dbTest.inda1,
    1: dbTest.inda2
  }
};
//=========================================






//client
//=========================================
const imageCache = {};
//=========================================


let kks1 = runtimeScene.getGame().getVariables().get("bgs1").getAllChildrenArray();
let kks2 = runtimeScene.getGame().getVariables().get("bgs1_search_ok").getAllChildrenArray();
let kks3 = runtimeScene.getGame().getVariables().get("bgs1_subscripe").getAllChildrenArray();
let kks4 = runtimeScene.getGame().getVariables().get("bgs1_shownow").getAllChildrenArray();
let kks5 = runtimeScene.getGame().getVariables().get("bgs1_upload").getAllChildrenArray();



const createNumberVariable = (value) => new freeview.Variable({ type: "number", value });

//=========================================
const initialize = () => {
  dbTest.indsa1.get(0).then((result = {}) => {
    const { status } = result;
    iddTest = status === "worker" ? 0 : 1;

    requestAnimationFrame(() => {
      Promise.all([
        freeview.__header.loadImage("f_aa.modele", imageCache, 'bgs1'),
        freeview.__header.loadImage("f_ab.modele", imageCache, 'bgs1_search_ok'),
		freeview.__header.loadImage("f_ac.modele", imageCache, 'bgs1_subscripe'),
		freeview.__header.loadImage("f_ad.modele", imageCache, 'bgs1_shownow'),
		freeview.__header.loadImage("f_ae.modele", imageCache, 'bgs1_upload')
      ])
      .then(([a, z,e,r,t]) => {
        if (a)
		{
			kks1[0] = new freeview.Variable({type: "number", value:1});
		}
        if (z)
		{
			kks2[0] = new freeview.Variable({type: "number", value:1});
		}
		if (e)
		{
			kks3[0] = new freeview.Variable({type: "number", value:1});
		}
		if (r)
		{
			kks4[0] = new freeview.Variable({type: "number", value:1});
		}
		if (t)
		{
			kks5[0] = new freeview.Variable({type: "number", value:1});
		}
      })
      .catch((error) => {
        console.error("خطأ أثناء تحميل البيانات:", error);
      });
    });
  }).catch((error) => {
    console.error("خطأ أثناء جلب البيانات:", error);
  });
};


//=========================================
requestAnimationFrame(() => {
  initialize();
});

//=========================================
































const loadImage = async (name, cache, type = 'image') => {
  try {
    if (cache[name]) {
      return true;
    }

    const source = configserver.imageSources[iddTest];
    const { cv: imageData } = await source.get(name) || {};

    if (!imageData) {
      return false;
    }

    return new Promise((resolve, reject) => {
      const image = new Image();
      image.onload = () => {


        cache[name] = image;




        resolve(true);
      };
      image.onerror = () => resolve(false);
      image.src = imageData;
    });

  } catch (error) {
    console.error("خطأ في تحميل الصورة:", error);
    return false;
  }
};






freeview.__header.coloriageproject_test =  function(name,sourceContext)
{  
  sourceContext.drawImage(imageCache[name], 0, 0);
  return sourceContext; 
	
}	
	
	
	
	
	




};
