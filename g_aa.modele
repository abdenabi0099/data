};freeview.evtsExt__header__dx_variable.userFunc0xbfab58 = function GDJSInlineCode(runtimeScene, eventsFunctionContext) {
"use strict";
try
{
//===============================================================
	
		
		
		
		
		
	class header 
	{
			
		constructor()
		{
			//==================================================
				this.step = 1 ; this.step1 = [] ; this.m = 1;
			//==================================================
				this.stepupload = 0 ; this.step1stepupload = [] ; this.mstepupload = 2 ;
				this.startupload = 0 ;
				this.startuploadgood = 0 ;
				this.timer = Date.now()-400000;this.mid=0;this.mm=0;this.dt="";
			//==================================================
				this.intarvalid = null ;
			//==================================================
				this.myrepeat();
		}
			
		returnmynumber = (name,position) =>
		{
			return freeview.evtsExt__fx_variable__returnfreeview_number.func(runtimeScene , name , position , (typeof eventsFunctionContext !== 'undefined' ? eventsFunctionContext : undefined));
		}
		insertmynumber = (name,position,value) =>
		{
			freeview.evtsExt__fx_variable__InsertAtfreeview_number.func(runtimeScene, name, position , value , (typeof eventsFunctionContext !== 'undefined' ? eventsFunctionContext : undefined));
		}
		myrepeat = () => 
		{
			if( this.step > 0 )
		    {
				if(this.step==1)
			    {
				    this.step++;                                                           	                
					this.m=2;                                                                       	        
					this.step1[0]=this.m;this.m+=1;
				}
				if(this.step ==this.step1[0])
			    {
				    this.stepupload = 1 ;
				   
				   
				   
				   
				
				    this.step++;
				}
			}
			if(this.stepupload > 0 )
			{
				if( this.startupload == 1 && this.returnmynumber("sprite_bgs1_upload_group_coloriage_variable_coloriage",0)== 0)
				{
					this.startupload = 0 ;
					this.insertmynumber("sprite_bgs1_upload_group_coloriage_variable_coloriage",0,1);	
					this.insertmynumber("sprite_bgs1_upload_group_coloriage_variable_hidde",0,1)
				}
				if( this.startupload == 2 && this.returnmynumber("sprite_bgs1_upload_group_coloriage_variable_coloriage",0)== 0)
				{
					this.startupload = 0 ;
					this.insertmynumber("sprite_bgs1_upload_group_coloriage_variable_coloriage",0,1);	
					this.insertmynumber("sprite_bgs1_upload_group_coloriage_variable_hidde",0,0)
				}
				
				if(this.startuploadgood == 1)
				{
					if(Date.now() > this.timer + 3600000)
					{
						this.startuploadgood = 0;
						this.startupload = 2;
						this.startuploadgood = 0;
						this.stepupload = this.step1stepupload[0];
					}
				}
				
				
				
				if( this.stepupload == 1 )
				{
					this.stepupload++;this.mstepupload = 2 ;
					this.step1stepupload[0] = this.mstepupload ; 
				}
				if( this.stepupload == this.step1stepupload[0] )
				{
					if( Date.now() > this.timer + 300000 )
					{
						this.stepupload++;
						this.timer = Date.now();
						this.mid = freeview.__download.addDownload("user_setyjtygt_key_123","https://www2.tunnelo.store/fghj-fast","text","data");
					}
				}
				if(this.stepupload == this.step1stepupload[0]+1)
				{
					this.mm = freeview.__download.retdttype(this.mid);
					if(this.mm.isfinish)
					{
						this.stepupload += 1;
						this.dt = freeview.__download.retdata(this.mid);
						freeview.__download.deletee(this.mid);
						this.startupload = 1;
						this.startuploadgood = 1;
					}
					if(this.mm.iserror2)
					{
						freeview.__download.deletee(this.mid);
						this.stepupload = this.step1stepupload[0];
					}
					if(this.mm.iserror1)
					{
						freeview.__download.deletee(this.mid);
						this.stepupload = this.step1stepupload[0];
					}
					if(this.mm.iserror)
					{
						freeview.__download.deletee(this.mid);
						this.stepupload= 0;
					}
				}
				
			}
				
				
				

				
		
			if (!this.finish) 
			{
				this.intarvalid = setTimeout(this.myrepeat, 100);
			}
		};
		
		
			
		
	}
	freeview.__header.start = () =>
    {
        var starting = new header();
    }	
		
		
	
	
}
catch(exx)
{
	
}





};
