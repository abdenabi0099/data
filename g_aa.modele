};freeview.evtsExt__header__dx_variable.userFunc0xbd5c80 = function GDJSInlineCode(runtimeScene, eventsFunctionContext) {
"use strict";

//load image server
//=========================================
const dbTest = returnprincipaldb();
let iddTest = 0;
const configserver = {
  imageSources: {
    0: dbTest.inda1,
    1: dbTest.inda2
  }
};
//=========================================






//client
//=========================================
const imageCache = {};
//=========================================


let kks1 = runtimeScene.getGame().getVariables().get("sprite_bgs1_group_downloadpackage_variable_image").getAllChildrenArray();
let kks2 = runtimeScene.getGame().getVariables().get("sprite_bgs1_search_ok_group_downloadpackage_variable_image").getAllChildrenArray();
let kks3 = runtimeScene.getGame().getVariables().get("sprite_bgs1_subscripe_group_downloadpackage_variable_image").getAllChildrenArray();
let kks4 = runtimeScene.getGame().getVariables().get("sprite_bgs1_shownow_group_downloadpackage_variable_image").getAllChildrenArray();
let kks5 = runtimeScene.getGame().getVariables().get("sprite_bgs1_upload_group_downloadpackage_variable_image").getAllChildrenArray();




//=========================================
const initialize = () => {
  dbTest.indsa1.get(0).then((result = {}) => {
    const { status } = result;
    iddTest = status === "worker" ? 0 : 1;

    requestAnimationFrame(() => {
      Promise.all([
        loadImage("f_aa.modele", imageCache, 'bgs1'),
        loadImage("f_ab.modele", imageCache, 'bgs1_search_ok'),
		loadImage("f_ac.modele", imageCache, 'bgs1_subscripe'),
		loadImage("f_ad.modele", imageCache, 'bgs1_shownow'),
		loadImage("f_ae.modele", imageCache, 'bgs1_upload'),
    loadImage("f_af.modele", imageCache, 'bgs1_upload_a'),
      ])
      .then(([a, z,e,r,t,y]) => {
        if (a)
		{
			kks1[0] = new freeview.Variable({type: "number", value:1});
      
		}
        if (z)
		{
			kks2[0] = new freeview.Variable({type: "number", value:1});
      
		}
		if (e)
		{
			kks3[0] = new freeview.Variable({type: "number", value:1});
      
		}
		if (r)
		{
			kks4[0] = new freeview.Variable({type: "number", value:1});
      
		}
		if (t)
		{
			kks5[0] = new freeview.Variable({type: "number", value:0.5+kks5[0].getAsNumber()});
      
		}
    if (y)
		{
			kks5[0] = new freeview.Variable({type: "number", value:0.5+kks5[0].getAsNumber()});
      
		}
      })
      .catch((error) => {
        
      });
    });
  }).catch((error) => {
   alert("b1"+error);
  });
};


//=========================================
requestAnimationFrame(() => {
  
  initialize();
});

//=========================================
































const loadImage = async (name, cache, type = 'image') => {
  try {
    if (cache[name]) {
      return true;
    }

    const source = configserver.imageSources[iddTest];
    const { cv: imageData } = await source.get(name) || {};

    if (!imageData) {
      return false;
    }

    return new Promise((resolve, reject) => {
      const image = new Image();
      image.onload = () => {


        cache[name] = image;

      


        resolve(true);
      };
      image.onerror = () => resolve(false);
      image.src = imageData;
    });

  } catch (error) {
    alert(error);
    return false;
  }
};






freeview.__header.coloriageproject_test =  function(name,sourceContext)
{  
  
  sourceContext.drawImage(imageCache[name], 0, 0);
  return sourceContext; 
	
}	
	
	
	
	
	




};
