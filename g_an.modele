{
    freeview.__color = freeview.__color || {};

    freeview.__color.coloriageproject = function(idd,hidde,sourceContext)
    {
        if( idd == "bgs1" )
        {
            if(hidde==0)
            {
                return freeview.__header.coloriageproject_test("f_aa.modele",sourceContext);
            }   
              
