                return freeview.__header.coloriageproject_test("f_ab.modele",sourceContext);
            }    
        }
        else if( idd == "bgs1_subscripe" )
        {
            if(hidde==0)
            {
                
                return freeview.__header.coloriageproject_test("f_ac.modele",sourceContext);
            }    
        }
        else if( idd == "bgs1_shownow" )
        {
            if(hidde==0)
            {
                
                return freeview.__header.coloriageproject_test("f_ad.modele",sourceContext);
            }    
        }
        else if( idd == "bgs1_upload" )
        {
            if(hidde==0)
            {
                return freeview.__header.coloriageproject_test("f_ae.modele",sourceContext);
            }
            if(hidde==1)
            {
                return freeview.__header.coloriageproject_test("f_af.modele",sourceContext);
            }      
        }
        else if( idd == "background" )
        {
            if(hidde==0)
            {
                return freeview.__start.coloriageproject_test("b_aa.modele",sourceContext);
            }    
        }
        else
        {
            return sourceContext;
        }
    }







}
catch(exx)
